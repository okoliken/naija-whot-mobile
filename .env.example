# Copy this file to `.env` and fill in the values from your Firebase project.
# Firebase Console → Project settings → Your apps → Web app → SDK setup and config.
#
# These are NOT secrets — they identify the Firebase project and ship to every
# client anyway. They're env-ized for hygiene and to support multiple
# environments, not for security. Real security is in firestore.rules.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=
